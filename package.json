{
  "name": "pipewright",
  "version": "0.1.0",
  "description": "Lightweight TypeScript DAG workflow engine with typed nodes and human-in-the-loop approval gates",
  "keywords": ["workflow", "dag", "pipeline", "typescript", "zod", "orchestration"],
  "repository": { "type": "git", "url": "https://github.com/onblueroses/pipewright" },
  "homepage": "https://github.com/onblueroses/pipewright",
  "bugs": { "url": "https://github.com/onblueroses/pipewright/issues" },
  "license": "MIT",
  "engines": { "node": ">=18" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "pack:check": "npm pack --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
